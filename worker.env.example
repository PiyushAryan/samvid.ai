APP_ENV=production
APP_ACCESS_PASSWORD=
FRONTEND_ORIGIN=https://samvid-ai.vercel.app
DATABASE_URL=
AUTO_INITIALIZE_DATABASE=false

# The current workers do not enforce request limits, but retain these values for
# shared runtime configuration and future admission-aware worker tasks.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_MODE=observe

DOCUMENT_STORAGE_BACKEND=vercel_blob
BLOB_READ_WRITE_TOKEN=
INBOUND_ATTACHMENT_DIR=/tmp/samvid/inbound-email

CONTRACT_PROCESSING_MODE=rabbitmq
RABBITMQ_URL=
RABBITMQ_EXCHANGE=contract.events
RABBITMQ_REVIEW_QUEUE=contract.review.q
RABBITMQ_RETRY_QUEUE=contract.review.retry.q
RABBITMQ_DLQ=contract.review.dlq
RABBITMQ_RETRY_TTL_MS=60000
RABBITMQ_MAX_ATTEMPTS=3
RABBITMQ_HEARTBEAT_SECONDS=600
RABBITMQ_KNOWLEDGE_INDEX_QUEUE=contract.knowledge-index.q
RABBITMQ_KNOWLEDGE_INDEX_RETRY_QUEUE=contract.knowledge-index.retry.q
RABBITMQ_KNOWLEDGE_INDEX_DLQ=contract.knowledge-index.dlq

MODEL_PROVIDER=openai
MODEL_ID=gpt-5-mini
OPENAI_API_KEY=
AGENTIC_CHAT_ENABLED=false
CHAT_MODEL_ID=gpt-5-mini
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
EMBEDDING_MODEL_ID=fireworks/qwen3-embedding-8b
EMBEDDING_DIMENSIONS=1024
RERANK_MODEL_ID=fireworks/qwen3-reranker-8b
MAX_FILE_SIZE_MB=20

ENABLE_OCR=true
OCR_PROVIDER=sarvam
SARVAM_API_KEY=
SARVAM_OCR_LANGUAGE=en-IN
SARVAM_OCR_TIMEOUT_SECONDS=600
SARVAM_OCR_MAX_CONCURRENCY=2

AUTO_SEND_REVIEW_EMAIL=true
EMAIL_FROM_ADDRESS=onboarding@resend.dev
RESEND_API_KEY=
LOG_LEVEL=INFO
